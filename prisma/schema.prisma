generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────
// NextAuth standard models
// ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  businessManagers BusinessManager[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────
// Domain models
// ──────────────────────────────────────────

model BusinessManager {
  id              String    @id @default(cuid())
  userId          String
  metaBmId        String    @unique
  name            String
  accessTokenEnc  String    @db.Text
  tokenExpiresAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccounts  AdAccount[]

  @@index([userId])
}

model AdAccount {
  id                String   @id @default(cuid())
  businessManagerId String
  metaAccountId     String   @unique
  name              String
  currency          String   @default("BRL")
  timezone          String   @default("America/Sao_Paulo")
  status            Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  businessManager BusinessManager @relation(fields: [businessManagerId], references: [id], onDelete: Cascade)
  campaigns       Campaign[]
  competitors     Competitor[]
  funnelAudits    FunnelAudit[]

  @@index([businessManagerId])
}

model Campaign {
  id              String         @id @default(cuid())
  adAccountId     String
  metaCampaignId  String         @unique
  name            String
  status          CampaignStatus
  dailyBudget     Float?
  spend           Float          @default(0)
  impressions     Int            @default(0)
  clicks          Int            @default(0)
  conversions     Int            @default(0)
  revenue         Float          @default(0)
  roas            Float          @default(0)
  cpm             Float          @default(0)
  frequency       Float          @default(0)
  aiAutoPilot     Boolean        @default(false)
  aiMinRoas       Float          @default(2.0)
  aiMaxFrequency  Float          @default(4.0)
  lastAiAction    String?
  lastAiActionAt  DateTime?
  metricsUpdatedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  adAccount AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@index([adAccountId])
}

model Competitor {
  id          String    @id @default(cuid())
  adAccountId String
  name        String
  url         String
  lastPrice   Float?
  currency    String    @default("BRL")
  lastChecked DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  adAccount AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@index([adAccountId])
}

model FunnelAudit {
  id                   String         @id @default(cuid())
  adAccountId          String
  type                 AuditIssueType
  severity             IssueSeverity  @default(MEDIUM)
  url                  String
  title                String
  description          String         @db.Text
  device               String?
  browser              String?
  resolved             Boolean        @default(false)
  resolvedAt           DateTime?
  estimatedRevenueLoss Float?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  adAccount AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@index([adAccountId])
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum CampaignStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
  IN_PROCESS
  WITH_ISSUES
}

enum AuditIssueType {
  BROKEN_CTA
  HIGH_PRICE
  SLOW_PAGE
  MOBILE_UX
  CHECKOUT_ERROR
  PIXEL_FAILURE
  HIGH_SHIPPING
  COMPETITOR_CHEAPER
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
